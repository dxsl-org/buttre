import { TabWidget, ComboBox, CheckBox, Button, LineEdit, VerticalBox, HorizontalBox, ScrollView } from "std-widgets.slint";

export struct LearnedWordRow {
    word: string,
    count: int,
}

export struct MacroRow {
    trigger: string,
    expand: string,
    enabled: bool,
}

export component ConfigWindow inherits Window {
    title: "buttre — Cấu hình";
    preferred-width: 520px;
    preferred-height: 420px;
    min-width: 460px;
    min-height: 360px;

    // Mirrors `buttre_core::state::Settings` field-for-field — `run()` sets
    // these from `Settings::load()` and reads them back in `on-save`.
    in-out property <[string]> method-names: ["English", "Telex", "VNI"];
    in-out property <int> method-index: 1;
    // Display text of the selected method — kept in lock-step with
    // `method-index` by `run()` because ComboBox does not re-render its
    // value when only the index is set programmatically.
    in-out property <string> method-value: "";
    in-out property <bool> autostart: false;
    in-out property <bool> raw-backspace: false;
    in-out property <bool> learning-enabled: true;
    in-out property <bool> shorthand-enabled: false;

    // `run()` handles this: build a `Settings` from the properties above and
    // atomically save it. Fired by EVERY user change on the "Chung" tab
    // (instant-apply — there is no explicit save button; the tray's file
    // watcher picks each write up live).
    callback save-settings();
    // Close the window ("Đóng") — settings are already saved on change.
    callback close-window();

    // ── Từ đã học ─────────────────────────────────────────────────────────
    in property <[LearnedWordRow]> learned-words: [];
    callback delete-learned-word(string);
    callback clear-learned-words();
    callback open-learning-file();

    // ── Gõ tắt ────────────────────────────────────────────────────────────
    in property <[MacroRow]> macro-rows: [];
    // (old-trigger, new-trigger, expand, enabled) -> success. Add if
    // old-trigger is empty, else rename/edit the row whose CURRENT trigger
    // is old-trigger. Rust sets `macro-form-message`/`-is-error` BEFORE
    // returning; the form only clears on `true`.
    callback save-macro(string, string, string, bool) -> bool;
    callback delete-macro(string);
    callback open-macros-file();
    in property <string> macro-form-message: "";
    in property <bool> macro-form-is-error: false;

    // ── Giới thiệu ────────────────────────────────────────────────────────
    // `run()` sets this from `env!("CARGO_PKG_VERSION")` — single-sourced
    // from Cargo.toml so the version string can never drift out of sync
    // with a hardcoded literal (the bug the old help_dialog.rs MessageBox
    // had: "0.7.7-beta" baked in, silently stale after every release bump).
    in property <string> version: "";
    callback open-url(string);
    // Purely local UI state (the add/edit form below the macro table) —
    // never touched from Rust. Empty `editing-trigger` = "add new" mode;
    // non-empty = editing the row whose CURRENT trigger matches it.
    property <string> editing-trigger: "";
    property <string> form-trigger: "";
    property <string> form-expand: "";
    property <bool> form-enabled: true;

    VerticalBox {
        // App identity lives ABOVE the tab bar so it is visible from every
        // tab — the "Giới thiệu" tab keeps only the long-form content.
        Text {
            text: "buttre — Bộ Gõ Tiếng Việt";
            font-weight: 700;
            font-size: 16px;
        }
        Text {
            text: "Phiên bản: " + root.version;
            color: gray;
        }
        TabWidget {
            Tab {
                title: "Chung";
                VerticalBox {
                    // Pack controls at the top with their preferred heights —
                    // without this the box distributes the tab's spare
                    // vertical space across children and the ComboBox row
                    // balloons.
                    alignment: start;
                    HorizontalBox {
                        Text {
                            text: "Kiểu gõ mặc định:";
                            vertical-alignment: center;
                        }
                        ComboBox {
                            model: method-names;
                            current-index <=> method-index;
                            // Two-way on the displayed text too: setting
                            // current-index from Rust alone does not refresh
                            // the rendered value, so the box would keep
                            // showing the first entry ("English") no matter
                            // which method is actually active.
                            current-value <=> method-value;
                            // User-initiated only (programmatic sets don't
                            // fire it) — safe with run()'s post-frame
                            // selection re-assert.
                            selected => { root.save-settings(); }
                        }
                    }
                    CheckBox {
                        text: "Tự động khởi động cùng hệ điều hành";
                        checked <=> autostart;
                        toggled => { root.save-settings(); }
                    }
                    CheckBox {
                        text: "Xóa lùi theo phím thô (thay vì theo ký tự hiển thị)";
                        checked <=> raw-backspace;
                        toggled => { root.save-settings(); }
                    }
                    CheckBox {
                        text: "Học thông minh (ghi nhớ âm tiết lạ + lựa chọn của bạn)";
                        checked <=> learning-enabled;
                        toggled => { root.save-settings(); }
                    }
                    CheckBox {
                        text: "Gõ tắt (macros.toml)";
                        checked <=> shorthand-enabled;
                        toggled => { root.save-settings(); }
                    }
                }
            }
            Tab {
                title: "Từ đã học";
                VerticalBox {
                    ScrollView {
                        VerticalLayout {
                            for row in root.learned-words: HorizontalBox {
                                Text {
                                    text: row.word;
                                    horizontal-stretch: 1;
                                    vertical-alignment: center;
                                }
                                Text {
                                    text: row.count + "x";
                                    color: gray;
                                    vertical-alignment: center;
                                }
                                Button {
                                    text: "Xóa";
                                    clicked => { root.delete-learned-word(row.word); }
                                }
                            }
                        }
                    }
                    if root.learned-words.length == 0: Text {
                        text: "Chưa học từ nào.";
                        color: gray;
                    }
                    HorizontalBox {
                        Button {
                            text: "Quên tất cả";
                            clicked => { root.clear-learned-words(); }
                        }
                        Button {
                            text: "Mở tệp gốc";
                            clicked => { root.open-learning-file(); }
                        }
                    }
                }
            }
            Tab {
                title: "Gõ tắt";
                VerticalBox {
                    ScrollView {
                        VerticalLayout {
                            for row in root.macro-rows: HorizontalBox {
                                // A disabled row is dimmed + labeled; the
                                // flag itself is only editable through the
                                // edit form ("Sửa") — no per-row toggle.
                                Text {
                                    text: row.trigger;
                                    horizontal-stretch: 1;
                                    vertical-alignment: center;
                                    opacity: row.enabled ? 1 : 0.45;
                                }
                                Text {
                                    text: row.expand;
                                    horizontal-stretch: 2;
                                    vertical-alignment: center;
                                    overflow: elide;
                                    opacity: row.enabled ? 1 : 0.45;
                                }
                                if !row.enabled: Text {
                                    text: "tắt";
                                    color: gray;
                                    vertical-alignment: center;
                                }
                                // "×" (U+00D7), not "✕" (U+2715): the
                                // latter has no glyph in the default UI
                                // font and renders as a tofu box.
                                Button {
                                    text: "✎";
                                    width: 32px;
                                    height: 32px;
                                    clicked => {
                                        editing-trigger = row.trigger;
                                        form-trigger = row.trigger;
                                        form-expand = row.expand;
                                        form-enabled = row.enabled;
                                    }
                                }
                                Button {
                                    text: "×";
                                    width: 32px;
                                    height: 32px;
                                    clicked => { root.delete-macro(row.trigger); }
                                }
                            }
                        }
                    }
                    if root.macro-rows.length == 0: Text {
                        text: "Chưa có gõ tắt nào.";
                        color: gray;
                    }
                    Rectangle {
                        height: 1px;
                        background: gray;
                    }
                    Text {
                        text: editing-trigger == "" ? "Thêm gõ tắt mới:" : "Đang sửa \"" + editing-trigger + "\":";
                        font-weight: 700;
                    }
                    HorizontalBox {
                        LineEdit {
                            placeholder-text: "gõ tắt (vd. vn)";
                            text <=> form-trigger;
                            width: 120px;
                        }
                        LineEdit {
                            placeholder-text: "thay bằng (vd. Việt Nam)";
                            text <=> form-expand;
                            horizontal-stretch: 1;
                        }
                        CheckBox {
                            text: "Bật";
                            checked <=> form-enabled;
                        }
                        Button {
                            text: editing-trigger == "" ? "Thêm" : "Lưu";
                            clicked => {
                                if (root.save-macro(editing-trigger, form-trigger, form-expand, form-enabled)) {
                                    editing-trigger = "";
                                    form-trigger = "";
                                    form-expand = "";
                                    form-enabled = true;
                                }
                            }
                        }
                        if editing-trigger != "": Button {
                            text: "Hủy";
                            clicked => {
                                editing-trigger = "";
                                form-trigger = "";
                                form-expand = "";
                                form-enabled = true;
                            }
                        }
                    }
                    if root.macro-form-message != "": Text {
                        text: root.macro-form-message;
                        color: root.macro-form-is-error ? red : darkorange;
                        wrap: word-wrap;
                    }
                }
            }
            Tab {
                title: "Giới thiệu";
                ScrollView {
                    VerticalBox {
                        Text {
                            text: "Giấy phép: GPL 3.0";
                        }
                        Text {
                            text: "Chuẩn mã: NFC (Unicode dựng sẵn)";
                        }
                        Rectangle { height: 8px; }
                        Text {
                            text: "KIỂU GÕ & PHÍM TẮT:";
                            font-weight: 700;
                        }
                        Text {
                            text: "• Ctrl+Shift+Space  →  Bật/Tắt tiếng Việt\n• Ctrl+Shift+1 → Telex\n• Ctrl+Shift+2 → VNI\n• Ctrl+Shift+3 → Nôm\n• Ctrl+Shift+4 → ...\n• Ctrl+Shift+Z → Đảo từ vừa gõ giữa nguyên văn/bỏ dấu";
                            wrap: word-wrap;
                        }
                        Rectangle { height: 8px; }
                        Text {
                            text: "HỌC THÔNG MINH:";
                            font-weight: 700;
                        }
                        Text {
                            text: "buttre ghi nhớ âm tiết lạ bạn gõ ≥3 lần và lựa chọn Ctrl+Shift+Z của bạn vào learning.toml. Xem/sửa ở tab \"Từ đã học\". Bật/tắt ở tab \"Chung\".";
                            wrap: word-wrap;
                        }
                        Rectangle { height: 8px; }
                        Text {
                            text: "GÕ TẮT:";
                            font-weight: 700;
                        }
                        Text {
                            text: "Tự định nghĩa chuỗi gõ tắt (vd. vn → Việt Nam) ở tab \"Gõ tắt\". Chỉ nổ khi gõ đúng nguyên cả từ. Đảo lại: Ctrl+Shift+Z. Bật/tắt ở tab \"Chung\".";
                            wrap: word-wrap;
                        }
                        Rectangle { height: 8px; }
                        Text {
                            text: "TÀI LIỆU & MÃ NGUỒN:";
                            font-weight: 700;
                        }
                        Text {
                            text: "github.com/dxsl-org/buttre";
                            color: blue;
                            TouchArea {
                                clicked => { root.open-url("https://github.com/dxsl-org/buttre"); }
                            }
                        }
                        Text {
                            text: "BÁO LỖI:";
                            font-weight: 700;
                        }
                        Text {
                            text: "github.com/dxsl-org/buttre/issues";
                            color: blue;
                            TouchArea {
                                clicked => { root.open-url("https://github.com/dxsl-org/buttre/issues"); }
                            }
                        }
                    }
                }
            }
        }
        HorizontalBox {
            alignment: end;
            Button {
                text: "Đóng";
                primary: true;
                clicked => {
                    close-window();
                }
            }
        }
    }
}
